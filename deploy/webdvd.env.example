# Copy to /etc/webdvd.env on the VPS and edit. Owned by root, 0640.
# Referenced by /etc/systemd/system/webdvd.service.

# Required for auth (anything truthy enables auth). If unset, all discs
# become accessible without a login.
PLAYER_PASSWORD=change-me

# Cap on concurrent ffmpeg processes. Set to your CPU count or one less.
# Cache hits bypass this entirely; only cold transcodes count.
MAX_CONCURRENT_TRANSCODES=3

# How long a queued request waits for a slot before returning 503.
TRANSCODE_QUEUE_TIMEOUT_SECS=30
